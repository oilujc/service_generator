### 3. Implementation Standards

#### Model Template (`app/models/entity_model.py`)

```python
from typing import Dict, Any, Optional
from pydantic import BaseModel, Field

class Entity(BaseModel):
    id: Optional[str] = None
    # fields...

    @staticmethod
    def fromJson(data: Dict[str, Any]) -> "Entity":
        if not data:
            return None
        return Entity(
            id=str(data.get("_id") or data.get("id")),
            # mapping...
        )

class EntityRequest(BaseModel):
    # Request/Input models
    pass
```

#### Repository Template (`app/database/repositories/entity_repository.py`)

```python
from pymongo.database import Database
from bson import ObjectId
from .base_repository import BaseRepository
from models.entity_model import Entity
from typing import Optional, List

class EntityRepository(BaseRepository):
    """
    Independent repository for Entity.
    Inherits CRUD operations from BaseRepository.
    """
    def __init__(self, db: Database):
        super().__init__(db, "entities")
    
    def get_entity(self, id: str) -> Optional[Entity]:
        """Fetch single entity and convert to model."""
        data = self.get_by_id(id)
        return Entity.fromJson(data) if data else None
    
    def get_all_entities(self, filter_query: Dict[str, Any] = {}) -> List[Entity]:
        """Fetch all entities and convert to models."""
        data_list = self.get_all(filter_query)
        return [Entity.fromJson(data) for data in data_list if data]
    
    # Custom queries using pymongo operations
    def update_field(self, entity_id: str, field: str, value: Any):
        self.collection.update_one(
            {"_id": ObjectId(entity_id)},
            {"$set": {field: value}}
        )
```

