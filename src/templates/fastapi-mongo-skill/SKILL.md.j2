#### Router Template (`app/router/entity.py`)

```python
from fastapi import APIRouter, Depends, Body
from dependencies import get_entity_service, get_db
from services.entity_service import EntityService
from models.entity_model import Entity, EntityRequest
from pymongo.database import Database

router = APIRouter(prefix="/entities", tags=["Entity"])

@router.post("/", status_code=201)
def create_entity(
    data: EntityRequest = Body(...),
    service: EntityService = Depends(get_entity_service)
):
    entity_id = service.create_entity(**data.dict())
    return {"id": entity_id, "message": "Entity created successfully"}

@router.get("/{entity_id}", response_model=Entity)
def get_entity(
    entity_id: str,
    service: EntityService = Depends(get_entity_service)
):
    return service.get_entity(entity_id)

# Additional routes...
```

#### Dependency Template (`app/dependencies.py`)

```python
from fastapi import Depends
from pymongo.database import Database
from database.database import get_db
from services.entity_service import EntityService

def get_entity_service(db: Database = Depends(get_db)) -> EntityService:
    return EntityService(db)
```

